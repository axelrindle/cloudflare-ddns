{
    "private": true,
    "name": "cloudflare-ddns",
    "description": "🤖 Cloudflare Worker for mass-updating DNS records",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "./wranglerw dev",
        "deploy": "./wranglerw deploy --minify --secrets-file .env.production",
        "cf-typegen": "./wranglerw types --env-interface CloudflareBindings src/gen/wrangler.d.ts",
        "pages": "bun run src/pages.ts",
        "lint": "eslint --concurrency auto",
        "lint:inspect": "bunx @eslint/config-inspector --open=false"
    },
    "dependencies": {
        "@hono/standard-validator": "^0.2.2",
        "@hono/zod-validator": "^0.7.6",
        "@scalar/hono-api-reference": "^0.10.10",
        "hono": "^4.12.15",
        "hono-openapi": "^1.3.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@actcoding/eslint-config": "^0.0.12-2",
        "@cloudflare/workers-utils": "^0.18.0",
        "@eslint/config-inspector": "^2.0.0",
        "@eslint/json": "^1.2.0",
        "@scalar/types": "^0.9.2",
        "@types/bun": "^1.3.13",
        "@types/node": "^25.6.0",
        "chalk": "^5.6.2",
        "dotenv": "^17.4.2",
        "eslint": "^10.2.1",
        "wrangler": "^4.85.0"
    }
}
